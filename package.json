{
  "name": "mioku",
  "version": "0.8.0",
  "author": "Jerryplusy",
  "license": "MIT",
  "engines": {
    "node": ">= 22.18.0"
  },
  "description": "Mioku - Plugin framework extended from mioki for NapCat OneBot v11",
  "private": false,
  "workspaces": [
    "packages/*",
    "example"
  ],
  "scripts": {
    "start": "cd example && bun run start",
    "dev": "cd packages/mioku && bun run dev",
    "build": "cd packages/mioku && bun run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitepress": "^1.0.0"
  }
}
